# The patch in this file will make PractRand be Arm-processor Mac-compatible (M1/M2/...).
# To apply it download PractRand version 0.96 (it might work on newer versions but no
# guarantees) into a folder PractRand (see https://sourceforge.net/projects/pracrand).
# Then enter PractRand with cd and issue:
#
#    patch -p1 < path/to/practrand.patch
#
# Compile PractRand (may give harmless warnings) and link with:
#
#    c++ -c -O3 -std=c++11 src/*.cpp src/RNGs/*.cpp src/RNGs/other/*.cpp -Iinclude
#    ar rcs PractRand.a *.o
#    c++ -o RNG_test tools/RNG_test.cpp PractRand.a -O3 -std=c++11 -Iinclude -Itools -pthread
#
# Then pipe randompack generated randoms into RNG_test with:
#
#    cd <randompack-root>/release/examples
#    RawStream -e x128+ | RNG_test stdin64    # to see failure
#    RawStream -e x256++ | RNG_test stdin64   # to run continuously without failure

  diff --git a/src/platform_specifics.cpp b/src/platform_specifics.cpp
  index 2eaeb3b..a7d8b5d 100644
  --- a/src/platform_specifics.cpp
  +++ b/src/platform_specifics.cpp
  @@ -10,8 +10,8 @@
   #ifdef _MSC_VER
   #include <intrin.h>
   #endif
  -#ifdef __GNUC__
  +#if defined(__GNUC__) && (defined(__i386__) || defined(__x86_64__))
   #include <x86intrin.h>
   #endif
   #include <string>
  @@ -42,11 +42,12 @@ using namespace PractRand;
   Sint64 PractRand::Internals::high_resolution_time() {
   #if defined _MSC_VER && ((defined _M_IX86 && _M_IX86 >= 500) || defined _M_X64 || defined _M_AMD64)
   	return __rdtsc();
  -#elif defined __GNUC__
  +#elif (defined __GNUC__ || defined __clang__) && (defined(__i386__) || defined(__x86_64__))
   	return __rdtsc();
   #else
  -	return std::chrono::high_resolution_clock();
  +	return (Sint64)std::chrono::duration_cast<std::chrono::nanoseconds>(
  +		std::chrono::high_resolution_clock::now().time_since_epoch()).count();
   #endif
   }
  diff --git a/tools/dummy_rng.h b/tools/dummy_rng.h
  index 3b6052b..3c42a64 100644
  --- a/tools/dummy_rng.h
  +++ b/tools/dummy_rng.h
  @@ -15,7 +15,7 @@ Actually, I change this all the time to whatever I'm looking at the moment - I s

   */

  -#if defined __GNUC__
  +#if defined(__GNUC__) && (defined(__i386__) || defined(__x86_64__))
   #include <x86intrin.h>
   #endif
  diff --git a/tools/RNG_benchmark.cpp b/tools/RNG_benchmark.cpp
  index 49c33c7..7ac0ce7 100644
  --- a/tools/RNG_benchmark.cpp
  +++ b/tools/RNG_benchmark.cpp
  @@ -35,8 +35,8 @@

   #ifdef _MSC_VER
   #include <intrin.h>
  -#else
  -#include <x86intrin.h>
  +#elif defined(__i386__) || defined(__x86_64__)
  +#include <x86intrin.h>
   #endif
   using namespace PractRand;
   #include "Candidate_RNGs.h"
